---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
}

const { title, description, date, tags } = Astro.props;
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`${title} | Martin Shterjoski`} description={description}>
  <div class="pt-24 pb-16">
    <article class="max-w-3xl mx-auto px-6">
      <a
        href={`${import.meta.env.BASE_URL}/blog/`}
        class="inline-flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-accent-500 dark:hover:text-accent-400 transition-colors mb-8"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        Back to blog
      </a>

      <header class="mb-12">
        <time class="text-sm text-accent-500 dark:text-accent-400 font-medium">{formattedDate}</time>
        <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mt-2 mb-4 leading-tight">
          {title}
        </h1>
        <p class="text-lg text-slate-500 dark:text-slate-400">{description}</p>
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="text-xs px-2.5 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">
              {tag}
            </span>
          ))}
        </div>
      </header>

      <div class="prose prose-slate dark:prose-invert prose-headings:font-bold prose-a:text-accent-500 dark:prose-a:text-accent-400 prose-code:text-accent-600 dark:prose-code:text-accent-300 max-w-none
        [&>h2]:text-2xl [&>h2]:mt-12 [&>h2]:mb-4 [&>h2]:text-slate-900 dark:[&>h2]:text-white
        [&>h3]:text-xl [&>h3]:mt-8 [&>h3]:mb-3 [&>h3]:text-slate-900 dark:[&>h3]:text-white
        [&>p]:text-slate-600 dark:[&>p]:text-slate-400 [&>p]:leading-relaxed [&>p]:mb-6
        [&>ul]:text-slate-600 dark:[&>ul]:text-slate-400 [&>ul]:mb-6 [&>ul>li]:mb-2
        [&>ol]:text-slate-600 dark:[&>ol]:text-slate-400 [&>ol]:mb-6 [&>ol>li]:mb-2
        [&>blockquote]:border-accent-500 [&>blockquote]:text-slate-500 dark:[&>blockquote]:text-slate-400
        [&>strong]:text-slate-900 dark:[&>strong]:text-white">
        <slot />
      </div>
    </article>
  </div>
</Layout>

---
import { profile } from "../data/profile";

interface GitHubRepo {
  name: string;
  description: string | null;
  html_url: string;
  language: string | null;
  stargazers_count: number;
  fork: boolean;
}

let repos: GitHubRepo[] = [];
try {
  const response = await fetch(
    `https://api.github.com/users/${profile.githubUsername}/repos?sort=updated&per_page=30`
  );
  const allRepos: GitHubRepo[] = await response.json();
  repos = allRepos
    .filter((r) => !r.fork && (r.description || r.language))
    .sort((a, b) => b.stargazers_count - a.stargazers_count)
    .slice(0, 6);
} catch {
  // Gracefully degrade if GitHub API is unavailable
}

const langColors: Record<string, string> = {
  Java: "#b07219",
  JavaScript: "#f1e05a",
  TypeScript: "#3178c6",
  Python: "#3572A5",
  Vue: "#41b883",
  "C#": "#178600",
  HTML: "#e34c26",
  CSS: "#563d7c",
};
---

<section id="projects" class="py-24 md:py-32">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
      Projects<span class="text-accent-400">.</span>
    </h2>
    <p class="text-slate-400 mb-16 max-w-xl">
      Open source work and side projects on GitHub.
    </p>

    {repos.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {repos.map((repo) => (
          <a
            href={repo.html_url}
            target="_blank"
            rel="noopener noreferrer"
            class="group bg-slate-900/50 border border-slate-800 rounded-xl p-6 hover:border-accent-500/30 transition-colors flex flex-col"
          >
            <div class="flex items-center gap-2 mb-3">
              <svg
                class="w-4 h-4 text-slate-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"
                />
              </svg>
              <h3 class="text-sm font-semibold text-white group-hover:text-accent-400 transition-colors truncate">
                {repo.name}
              </h3>
            </div>

            {repo.description && (
              <p class="text-xs text-slate-400 leading-relaxed mb-4 flex-1 line-clamp-2">
                {repo.description}
              </p>
            )}

            <div class="flex items-center gap-4 mt-auto pt-2">
              {repo.language && (
                <span class="flex items-center gap-1.5 text-xs text-slate-500">
                  <span
                    class="w-2.5 h-2.5 rounded-full"
                    style={`background-color: ${langColors[repo.language] || "#8b949e"}`}
                  />
                  {repo.language}
                </span>
              )}
              {repo.stargazers_count > 0 && (
                <span class="flex items-center gap-1 text-xs text-slate-500">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                  {repo.stargazers_count}
                </span>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-slate-500">Unable to load repositories at this time.</p>
    )}

    <div class="mt-8 text-center">
      <a
        href={profile.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-accent-400 transition-colors"
      >
        View all repositories
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"
          />
        </svg>
      </a>
    </div>
  </div>
</section>

---
import { Icon } from "astro-icon/components";
import { skills } from "../data/profile";
---

<section id="skills" class="py-24 md:py-32 reveal-scale">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">
      <span data-i18n="skills.title">Technical Stack</span><span class="text-accent-400">.</span>
    </h2>
    <p class="text-slate-500 dark:text-slate-400 mb-16 max-w-xl" data-i18n="skills.subtitle">
      Technologies and tools I work with daily.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {skills.map((category) => (
        <div class="bg-white/50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-xl p-6 hover:border-accent-500/30 transition-colors" data-stagger>
          <p class="text-accent-500 dark:text-accent-400 text-xs font-medium uppercase tracking-widest mb-4" data-i18n={`skills.cat.${category.label}`}>
            {category.label}
          </p>
          <div class="flex flex-wrap gap-3">
            {category.items.map((item) => (
              <div class="flex items-center gap-2 bg-slate-100 dark:bg-slate-800/50 rounded-lg px-3 py-2">
                <Icon name={item.icon} class="w-5 h-5" />
                <span class="text-sm text-slate-700 dark:text-slate-300">{item.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

---
import { techProficiency } from "../data/profile";
---

<section class="py-24 md:py-32 bg-slate-900/30">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
      Proficiency<span class="text-accent-400">.</span>
    </h2>
    <p class="text-slate-400 mb-16 max-w-xl">
      Relative confidence level across my core technologies.
    </p>

    <div class="max-w-2xl space-y-5">
      {techProficiency.map((item, i) => (
        <div class="group">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-medium text-slate-300">{item.name}</span>
            <span class="text-xs text-slate-500">{item.level}%</span>
          </div>
          <div class="w-full h-2 bg-slate-800 rounded-full overflow-hidden">
            <div
              class="h-full rounded-full bg-gradient-to-r from-accent-600 to-accent-400"
              style={`width: ${item.level}%; animation: grow-bar 1s ease-out ${i * 0.1}s both;`}
            />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes grow-bar {
    from {
      width: 0%;
    }
  }
</style>

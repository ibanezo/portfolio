---
import { testimonials } from "../data/profile";
---

<section class="py-24 md:py-32 bg-slate-100/50 dark:bg-slate-900/30 transition-colors reveal">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">
      <span data-i18n="testimonials.title">Testimonials</span><span class="text-accent-400">.</span>
    </h2>
    <p class="text-slate-500 dark:text-slate-400 mb-16 max-w-xl" data-i18n="testimonials.subtitle">
      What colleagues say about working with me.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <div class="bg-white/50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-xl p-6 flex flex-col">
          <svg class="w-8 h-8 text-accent-500/20 mb-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed flex-1 mb-6" data-i18n={`testimonial.${i}`}>
            {t.quote}
          </p>
          <div class="border-t border-slate-200 dark:border-slate-800 pt-4">
            <p class="text-sm font-medium text-slate-900 dark:text-white">{t.author}</p>
            <p class="text-xs text-slate-500">{t.role} · {t.company}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

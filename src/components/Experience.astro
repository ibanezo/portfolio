---
import { experience } from "../data/profile";
---

<section id="experience" class="py-24 md:py-32">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
      Experience<span class="text-accent-400">.</span>
    </h2>
    <p class="text-slate-400 mb-16 max-w-xl">
      7+ years building backend systems across enterprise and startup
      environments.
    </p>

    <div class="relative">
      {/* Timeline line */}
      <div
        class="absolute left-[7px] top-2 bottom-2 w-px bg-slate-800"
      ></div>

      <div class="space-y-12">
        {experience.map((entry, i) => (
          <div class="relative pl-10">
            {/* Timeline dot */}
            <div
              class:list={[
                "absolute left-0 top-2 w-[15px] h-[15px] rounded-full border-2",
                i === 0
                  ? "bg-accent-500 border-accent-400"
                  : "bg-slate-900 border-slate-700",
              ]}
            />

            <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 hover:border-slate-700 transition-colors">
              <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-2">
                <div>
                  <h3 class="text-lg font-semibold text-white">
                    {entry.title}
                  </h3>
                  <p class="text-accent-400 font-medium">{entry.company}</p>
                </div>
                <div class="text-sm text-slate-500 mt-1 md:mt-0 md:text-right">
                  <p>{entry.period}</p>
                  <p>{entry.location}</p>
                </div>
              </div>

              {entry.bullets.length > 0 && (
                <ul class="mt-4 space-y-2">
                  {entry.bullets.map((bullet) => (
                    <li class="flex items-start gap-3 text-sm text-slate-400">
                      <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-accent-500/60 shrink-0" />
                      {bullet}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
